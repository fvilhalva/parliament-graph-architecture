# ==========================================
# 1. Banco de Dados e Arquivos de Dados
# ==========================================
# Ignora o banco SQLite (como você bem pontuou)
*.db
*.sqlite
*.sqlite3

# Ignora a pasta inteira de dados que o Docker vai gerar
# (Onde ficarão os JSONs da API e os CSVs/GEXF do Gephi)
/data/
*.csv
*.json
*.gexf

# ==========================================
# 2. Python e Ambientes Virtuais
# ==========================================
# Cache do Python (arquivos compilados)
__pycache__/
*.py[cod]
*$py.class

# Ambientes virtuais (caso você teste no Arch/Windows sem o Docker)
venv/
env/
.venv/

# ==========================================
# 3. Jupyter Notebooks (Ciência de Dados)
# ==========================================
# Se você usar notebooks para testar o TF-IDF antes de passar pro script
.ipynb_checkpoints/

# ==========================================
# 4. Configurações de IDE e SO
# ==========================================
# VS Code / PyCharm
.vscode/
.idea/

# Windows (já que você alterna entre Arch e Windows)
Thumbs.db
Desktop.ini

# ==========================================
# 5. Variáveis de Ambiente e Segurança
# ==========================================
# Nunca suba senhas ou chaves de API (mesmo que a da Câmara seja aberta, é boa prática)
.env