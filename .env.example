# ============================================================================
# PARLIAMENT GRAPH ARCHITECTURE - Environment configuration template
# ============================================================================
# Copy this file to .env and adjust the values as needed.

# --- LEGISLATURE ---
# Pilot legislature year (any year) used for focused analyses
PILOT_LEGISLATURE=2025
# Current legislature year for analysis
CURRENT_LEGISLATURE=2026
# Starting year of the historical dataset
LEGISLATURE_START=2006

# --- PATHS (relative to project root) ---
# SQLite database path
DB_PATH=data/parliament.db
# Cache directory for temporary files
CACHE_DIR=data/cache
# Output directory for GEXF graph exports
GEXF_DIR=data/gexf
# Output directory for CSV metrics
METRICS_DIR=data/metricas
# Output directory for plots
PLOTS_DIR=data/plots

# --- CHAMBER OF DEPUTIES API ---
# Base URL for the open data API
API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2
# HTTP request timeout (seconds)
API_TIMEOUT=30

# --- LOGGING ---
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- GRAPH ANALYSIS ---
# Minimum number of co-authorships to create an edge
MIN_COAUTHORSHIPS=3
# Minimum edge weight to keep an edge in the graph
MIN_EDGE_WEIGHT=1
# Expected number of communities for community detection
NUM_COMMUNITIES=5
