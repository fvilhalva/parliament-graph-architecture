# ============================================================================
# PARLIAMENT GRAPH ARCHITECTURE - Template de Configurações (.env.example)
# ============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário

# --- LEGISLATURA ---
# Ano da legislatura atual para análise
LEGISLATURA_ATUAL=2026
# Ano de início dos dados históricos
LEGISLATURA_INICIO=2006

# --- CAMINHOS (relativo à raiz do projeto) ---
# Caminho do banco de dados SQLite
DB_PATH=data/parliament.db
# Diretório de cache para arquivos temporários
CACHE_DIR=data/cache
# Diretório para exportação de grafos em formato GEXF
GEXF_DIR=data/gexf
# Diretório para exportação de métricas em CSV
METRICAS_DIR=data/metricas
# Diretório para exportação de gráficos/plots
PLOTS_DIR=data/plots

# --- API DA CÂMARA DOS DEPUTADOS ---
# URL base da API de dados abertos
API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2
# Timeout em segundos para requisições HTTP
API_TIMEOUT=30

# --- LOGGING ---
# Nível de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- ANÁLISE DE GRAFOS ---
# Número mínimo de coautorias para criar uma aresta
MIN_COAUTORIAS=3
# Peso mínimo da aresta para manter no grafo
MIN_PESO_ARESTA=1
# Número de comunidades esperadas na detecção
NUM_COMUNIDADES=5